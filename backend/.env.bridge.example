# AMI connection
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=supporthub
AMI_SECRET=change-this

# Support Hub backend API
BACKEND_BASE_URL=http://localhost:8081
TELEPHONY_API_KEY=dev-telephony-key
TELEPHONY_WEBHOOK_SECRET=

# Mapping defaults
AMI_CLIENT_ID=1
AMI_QUEUE_NAME=support-main
AMI_RECONNECT_MS=5000
AMI_DEDUPE_WINDOW_MS=4000
AMI_STALE_CALL_MS=21600000
BRIDGE_HEALTH_PORT=9091

# File-backed outbox for failed event posts
BRIDGE_OUTBOX_PATH=/var/lib/supporthub/ami-outbox.ndjson
BRIDGE_REPLAY_INTERVAL_MS=5000
