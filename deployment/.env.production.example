# Copy to deployment/.env.production and update values
DOMAIN=supporthub.example.com
ACME_EMAIL=ops@example.com
POSTGRES_PASSWORD=change-this-strong-password
TELEPHONY_API_KEY=replace-with-strong-random-key
TELEPHONY_WEBHOOK_SECRET=replace-with-strong-webhook-secret
CORS_ORIGIN=https://supporthub.example.com
SESSION_TTL_HOURS=24

# Asterisk AMI bridge
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=supporthub
AMI_SECRET=change-this-ami-secret
AMI_CLIENT_ID=1
AMI_QUEUE_NAME=support-main
AMI_RECONNECT_MS=5000
AMI_DEDUPE_WINDOW_MS=4000
AMI_STALE_CALL_MS=21600000
BRIDGE_HEALTH_PORT=9091
BRIDGE_OUTBOX_PATH=/var/lib/supporthub/ami-outbox.ndjson
BRIDGE_REPLAY_INTERVAL_MS=5000
